  11. Schema Prisma Inicial

SCHEMA PRISMA

generator client {
  provider = "prisma-client-js"
}
REVISADO

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
}

enum Status {
  ATIVO
  INATIVO
}

model User {
  id                String @id @default(cuid())
  nome          String
  email          String @unique
  senha          String
  role             Role   @default(ADMIN)
}

model Aluno {
  id                             String      @id @default(cuid())
  nome                       String
  matricula                 String      @unique
  turmaId                   String
  dataNasc                 DateTime
  emailResponsavel   String
  fotoUrl                     String?

  // Relation field
  matriculas       Matricula[]
}


model Curso {
  id                      String      @id @default(cuid())
  nome                String
  descricao          String
  anoLetivo         String
  cargaHoraria    Int
  instrutor           String
  status               Status
  // Relation field
  matriculas      Matricula[]
}


model Matricula {
  id                  String   @id @default(cuid())
  alunoId         String
  cursoId         String
  dataInicio     DateTime @default(now())

  // Relations
  aluno  Aluno  @relation(fields: [alunoId], references: [id])
  curso  Curso   @relation(fields: [cursoId], references: [id])
  notas               Nota[]

  @@unique([alunoId, cursoId]) // evita matricula duplicada
}

model Nota {
  id                     String   @id @default(cuid())
  matriculaId      String
  descricao     String   
  valor            Float
  data              DateTime @default(now())

  // Relation
  matricula Matricula @relation(fields: [matriculaId], references: [id])
}

