generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PROFESSOR
  ALUNO
}

enum Status {
  ATIVO
  INATIVO
}

model User {
  id     String  @id @default(cuid())
  nome   String  @db.VarChar(100)
  email  String  @unique @db.VarChar(254)
  senha  String  @db.Char(60)
  role   Role    @default(ADMIN)

  cursos Curso[]
}

model Aluno {
  id             String      @id @default(cuid())
  nome           String      @db.VarChar(100)
  email          String      @unique @db.VarChar(254)
  dataNascimento DateTime    @db.Date
  fotoUrl        String?     @db.VarChar(500)
  fotoPublicId   String?     @db.VarChar(200)

  matriculas     Matricula[]
}

model Curso {
  id           String      @id @default(cuid())
  nome         String      @db.VarChar(100)
  descricao    String      @db.Text
  cargaHoraria Int
  instrutor    String      @db.VarChar(100)
  instrutorId  String?
  status       Status      @default(ATIVO)

  user         User?       @relation(fields: [instrutorId], references: [id])
  matriculas   Matricula[]
}

model Matricula {
  id         String   @id @default(cuid())
  alunoId    String
  cursoId    String
  dataInicio DateTime @default(now())

  aluno      Aluno    @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  curso      Curso    @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  notas      Nota[]

  @@unique([alunoId, cursoId])
}

model Nota {
  id          String    @id @default(cuid())
  matriculaId String
  descricao   String    @db.VarChar(100)
  valor       Decimal   @db.Decimal(4, 2)
  data        DateTime  @default(now())

  matricula   Matricula @relation(fields: [matriculaId], references: [id], onDelete: Cascade)
}
