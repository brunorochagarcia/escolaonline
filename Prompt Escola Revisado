7. Modelo de Dados

  enum Role   { ADMIN }
  enum Status { ATIVO · INATIVO }

  User
    id            String  @id @default(cuid())
    nome          String
    email         String  @unique
    senha         String  // hash bcrypt — nunca exposto via select
    role          Role    @default(ADMIN)

  Aluno
    id             String      @id @default(cuid())
    nome           String
    email          String      @unique
    dataNascimento DateTime
    fotoUrl        String?     // URL pública no Cloudinary
    fotoPublicId   String?     // ID interno para exclusão (rollback)
    matriculas     Matricula[]

  Curso
    id           String      @id @default(cuid())
    nome         String
    descricao    String
    cargaHoraria Int
    instrutor    String
    status       Status      @default(ATIVO)
    matriculas   Matricula[]

  Matricula
    id         String   @id @default(cuid())
    alunoId    String
    cursoId    String
    dataInicio DateTime @default(now())
    aluno      Aluno    @relation(fields: [alunoId], references: [id], onDelete: Cascade)
    curso      Curso    @relation(fields: [cursoId], references: [id], onDelete: Cascade)
    notas      Nota[]
    @@unique([alunoId, cursoId])   // RN-03

  Nota
    id          String    @id @default(cuid())
    matriculaId String
    descricao   String
    valor       Float     // 0.0 – 10.0
    data        DateTime  @default(now())
    matricula   Matricula @relation(fields: [matriculaId], references: [id], onDelete: Cascade)

